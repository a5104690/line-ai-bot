PORT=3000

# LINE Developers > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=replace_with_channel_access_token
LINE_CHANNEL_SECRET=replace_with_channel_secret

# OpenAI
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Optional. Comma-separated LINE user IDs that can use /admin commands.
ADMIN_USER_IDS=

# Optional. If set, messages containing this text trigger the bot in groups.
BOT_TRIGGER_NAME=@bot

# Optional. If true, every group text message is sent to AI. Usually too noisy.
RESPOND_TO_ALL_GROUP_MESSAGES=false
